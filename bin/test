#!/usr/bin/env bash

# Test runner for phpurs
# Compiles and runs PureScript passing tests.

ROOT_DIR=$(cd "$(dirname "$0")/.." && pwd)
TEST_DIR="$ROOT_DIR/tests"
PASSING_DIR="$TEST_DIR/passing"
RUNNER_DIR="$TEST_DIR/runner"

mkdir -p "$RUNNER_DIR/src"

cd "$RUNNER_DIR"

if [ ! -f spago.yaml ]; then
  cat << 'YAML' > spago.yaml
package:
  dependencies:
    - prelude
    - effect
    - console
    - arrays
    - partial
    - foldable-traversable
    - st
    - exceptions
    - integers
    - math
    - strings
    - enums
    - foreign-object
    - numbers
    - refs
    - unsafe-coerce
    - functions
    - unfoldable
    - record
    - assert
  name: runner
workspace:
  extraPackages:
    assert:
      path: "../../../phpurs-assert"
    prelude:
      path: "../../../phpurs-prelude"
    effect:
      path: "../../../phpurs-effect"
    console:
      path: "../../../phpurs-console"
    arrays:
      path: "../../../phpurs-arrays"
    partial:
      path: "../../../phpurs-partial"
    foldable-traversable:
      path: "../../../phpurs-foldable-traversable"
    st:
      path: "../../../phpurs-st"
    exceptions:
      path: "../../../phpurs-exceptions"
    integers:
      path: "../../../phpurs-integers"
    math:
      path: "../../../phpurs-math"
    strings:
      path: "../../../phpurs-strings"
    enums:
      path: "../../../phpurs-enums"
    foreign-object:
      path: "../../../phpurs-foreign-object"
    numbers:
      path: "../../../phpurs-numbers"
    refs:
      path: "../../../phpurs-refs"
    unsafe-coerce:
      path: "../../../phpurs-unsafe-coerce"
    functions:
      path: "../../../phpurs-functions"
    unfoldable:
      path: "../../../phpurs-unfoldable"
    record:
      path: "../../../phpurs-record"
  packageSet:
    registry: 73.3.0
YAML
fi

echo "Running tests from $PASSING_DIR..."

passed=0
failed=0

# Clean output (now handled inside the loop)

if [ $# -gt 0 ]; then
  TEST_FILES=()
  for arg in "$@"; do
    if [ -f "$PASSING_DIR/$arg" ]; then
      TEST_FILES+=("$PASSING_DIR/$arg")
    elif [ -f "$PASSING_DIR/$arg.purs" ]; then
      TEST_FILES+=("$PASSING_DIR/$arg.purs")
    else
      echo "Test file $arg not found."
    fi
  done
else
  # Use an array to store files safely
  TEST_FILES=("$PASSING_DIR"/*.purs)
fi

for test_file in "${TEST_FILES[@]}"; do
  test_name=$(basename "$test_file")
  echo "=> Testing $test_name"
  
  # Clean output and src for this specific test
  rm -rf output/Main src/*
  
  cp "$test_file" "src/Main.purs"
  
  if [ -f "${test_file%.purs}.js" ]; then
    cp "${test_file%.purs}.js" "src/Main.js"
  fi
  if [ -f "${test_file%.purs}.php" ]; then
    cp "${test_file%.purs}.php" "src/Main.php"
  fi
  
  test_dir="${test_file%.purs}"
  if [ -d "$test_dir" ]; then
    cp -r "$test_dir"/* "src/"
  fi
  
  # Try to build with spago (just generating corefn)
  if spago build -q > /dev/null 2>&1; then
    # Generate PHP code
    node ../../bin/phpurs.js > /dev/null 2>&1
    
    # Run the compiled PHP code
    if php output/Main/main.mod.php > /dev/null 2>&1; then
      echo -e "   \033[0;32m[OK]\033[0m"
      passed=$((passed+1))
    else
      echo -e "   \033[0;31m[FAILED]\033[0m Execution error"
      failed=$((failed+1))
      break
    fi
  else
    echo -e "   \033[0;31m[FAILED]\033[0m Compilation error"
    failed=$((failed+1))
    break
  fi
done

echo ""
if [ $failed -eq 0 ]; then
  echo -e "Summary: \033[0;32m$passed passed\033[0m, 0 failed."
else
  echo -e "Summary: \033[0;32m$passed passed\033[0m, \033[0;31m$failed failed\033[0m."
  exit 1
fi
