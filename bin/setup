#!/usr/bin/env bash

# Clones all core phpurs-* repositories as siblings of the phpurs directory.
# Useful for setting up the local development and testing environment.

ROOT_DIR=$(cd "$(dirname "$0")/.." && pwd)
SIBLING_DIR="$ROOT_DIR/.."

source "$(dirname "$0")/pkg"

echo "=> Cloning phpurs-* sibling repositories into $SIBLING_DIR..."

for pkg in "${CORE_PACKAGES[@]}"; do
  target="$SIBLING_DIR/phpurs-$pkg"
  if [ -d "$target" ]; then
    echo "[SKIP] phpurs-$pkg already exists."
  else
    echo "[CLONE] phpurs-$pkg..."
    git clone "https://github.com/0x000000000000000000001/phpurs-$pkg.git" "$target"
  fi
done

echo "=> Done! You can now run ./bin/test"
