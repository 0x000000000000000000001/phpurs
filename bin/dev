#!/bin/bash
set -e

# Run spago build in phpurs directory
cd "$(dirname "$0")/.."
echo "==> Rebuilding phpurs compiler in $(pwd)..."
spago build

# Now go to b8x
if [ ! -d "../b8x" ]; then
  echo "==> Error: b8x directory not found at ../b8x"
  echo "==> Please clone the b8x repository as a sibling to the phpurs directory to use the dev wrapper."
  exit 1
fi

cd ../b8x
echo "==> Generating PHP for b8x..."
node ../phpurs/bin/phpurs.js "$@"
echo "==> Done!"
