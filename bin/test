#!/usr/bin/env bash

# Test runner for phpurs
# Compiles and runs PureScript passing tests.

ROOT_DIR=$(cd "$(dirname "$0")/.." && pwd)
TEST_DIR="$ROOT_DIR/tests"
PASSING_DIR="$TEST_DIR/passing"
RUNNER_DIR="$TEST_DIR/runner"

# Tests to skip (e.g. tests using experimental compiler features not supported by our purs version)
BLACKLIST=(
  # For versions > 0.15
  "DerivingClause.purs"
  "DerivingContravariant.purs"
  "DerivingFunctorFromBi.purs"
  "DerivingFunctorFromPro.purs"
  "DerivingProfunctor.purs"
)

mkdir -p "$RUNNER_DIR/src"

echo "Building phpurs compiler..."
cd "$ROOT_DIR"
npm run build --silent || { echo -e "\n\033[0;31m[FAILED]\033[0m phpurs build failed!"; exit 1; }

cd "$RUNNER_DIR"

if [ ! -f spago.yaml ]; then
  cat << 'YAML' > spago.yaml
package:
  dependencies:
    - prelude
    - effect
    - console
    - arrays
    - partial
    - foldable-traversable
    - st
    - exceptions
    - integers
    - math
    - strings
    - enums
    - foreign-object
    - numbers
    - refs
    - unsafe-coerce
    - functions
    - unfoldable
    - record
    - assert
  name: runner
workspace:
  extraPackages:
    assert:
      path: "../../../phpurs-assert"
    prelude:
      path: "../../../phpurs-prelude"
    effect:
      path: "../../../phpurs-effect"
    console:
      path: "../../../phpurs-console"
    arrays:
      path: "../../../phpurs-arrays"
    partial:
      path: "../../../phpurs-partial"
    foldable-traversable:
      path: "../../../phpurs-foldable-traversable"
    st:
      path: "../../../phpurs-st"
    exceptions:
      path: "../../../phpurs-exceptions"
    integers:
      path: "../../../phpurs-integers"
    math:
      path: "../../../phpurs-math"
    strings:
      path: "../../../phpurs-strings"
    enums:
      path: "../../../phpurs-enums"
    foreign-object:
      path: "../../../phpurs-foreign-object"
    numbers:
      path: "../../../phpurs-numbers"
    refs:
      path: "../../../phpurs-refs"
    unsafe-coerce:
      path: "../../../phpurs-unsafe-coerce"
    functions:
      path: "../../../phpurs-functions"
    unfoldable:
      path: "../../../phpurs-unfoldable"
    record:
      path: "../../../phpurs-record"
  packageSet:
    registry: 73.3.0
YAML
fi

echo "Running tests from $PASSING_DIR..."

passed=0
failed=0

# Clean output (now handled inside the loop)

SKIP_BEFORE="" # E.g. "TCO" to run tests after TCO.purs
TEST_FILES=()
CLEAN_CACHE=0

if [ $# -gt 0 ]; then
  for arg in "$@"; do
    if [[ "$arg" == skip_before=* ]]; then
      SKIP_BEFORE="${arg#skip_before=}"
    elif [[ "$arg" == --skip-before=* ]]; then
      SKIP_BEFORE="${arg#--skip-before=}"
    elif [[ "$arg" == "-c" || "$arg" == "--clean" ]]; then
      CLEAN_CACHE=1
    else
      if [ -f "$ROOT_DIR/$arg" ]; then
        TEST_FILES+=("$ROOT_DIR/$arg")
      elif [ -f "$arg" ]; then
        TEST_FILES+=("$arg")
      elif [ -f "$PASSING_DIR/$arg" ]; then
        TEST_FILES+=("$PASSING_DIR/$arg")
      elif [ -f "$PASSING_DIR/$arg.purs" ]; then
        TEST_FILES+=("$PASSING_DIR/$arg.purs")
      else
        echo "Test file $arg not found."
      fi
    fi
  done
fi

if [ $CLEAN_CACHE -eq 1 ]; then
  echo "=> Cleaning Spago and output cache..."
  rm -rf .spago/* output-es/* output/*
fi

if [ ${#TEST_FILES[@]} -eq 0 ]; then
  # Use an array to store files safely
  TEST_FILES=("$PASSING_DIR"/*.purs)
fi

skipping_until=0
if [ -n "$SKIP_BEFORE" ]; then
  skipping_until=1
fi

for test_file in "${TEST_FILES[@]}"; do
  test_name=$(basename "$test_file")
  
  if [ $skipping_until -eq 1 ]; then
    if [[ "$test_name" == "$SKIP_BEFORE" || "$test_name" == "$SKIP_BEFORE.purs" ]]; then
      skipping_until=0
    else
      continue
    fi
  fi
  
  # Check blacklist
  skip_test=0
  for b in "${BLACKLIST[@]}"; do
    if [ "$test_name" = "$b" ]; then
      skip_test=1
      break
    fi
  done
  
  if [ $skip_test -eq 1 ]; then
    echo "=> Skipping $test_name (blacklisted)"
    continue
  fi

  echo "=> Testing $test_name"
  
  # Clean output and src for this specific test
  rm -rf output/Main src/*
  
  cp "$test_file" "src/Main.purs"
  
  if [ -f "${test_file%.purs}.js" ]; then
    cp "${test_file%.purs}.js" "src/Main.js"
  fi
  if [ -f "${test_file%.purs}.php" ]; then
    cp "${test_file%.purs}.php" "src/Main.php"
  fi
  
  test_dir="${test_file%.purs}"
  if [ -d "$test_dir" ]; then
    cp -r "$test_dir"/* "src/"
  fi
  
  # Try to build with spago (just generating corefn)
  retry=0
  max_retries=2
  build_success=0
  while [ $retry -le $max_retries ]; do
    if spago build -q > /dev/null 2>&1; then
      build_success=1
      break
    fi
    retry=$((retry+1))
  done

  if [ $build_success -eq 1 ]; then
    # Generate PHP code
    node ../../bin/phpurs.js > /dev/null 2>&1
    
    # Run the compiled PHP code
    if php output/Main/main.mod.php > /dev/null 2>&1; then
      echo -e "   \033[0;32m[OK]\033[0m"
      passed=$((passed+1))
    else
      echo -e "   \033[0;31m[FAILED]\033[0m Execution error"
      failed=$((failed+1))
      break
    fi
  else
    echo -e "   \033[0;31m[FAILED]\033[0m Compilation error"
    failed=$((failed+1))
    break
  fi
done

echo ""
if [ $failed -eq 0 ]; then
  echo -e "Summary: \033[0;32m$passed passed\033[0m, 0 failed."
else
  echo -e "Summary: \033[0;32m$passed passed\033[0m, \033[0;31m$failed failed\033[0m."
  exit 1
fi
